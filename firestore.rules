rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /settings/{document} {
      allow read, write: if true;
    }
    match /guesses/{document} {
      allow read, write: if true;
    }
    match /inviteCodes/{document} {
      allow read, write: if true;
    }
  }
}
